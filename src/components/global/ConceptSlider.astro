---
import { Picture } from "astro:assets";
import slide1 from "../../assets/images/concepr_slider_1.png";
import slide2 from "../../assets/images/concepr_slider_2.png";
import slide3 from "../../assets/images/concepr_slider_3.png";
import slide4 from "../../assets/images/concepr_slider_4.png";

const slides = [
  { image: slide1, text: "Abstraction And Architecture" },
  { image: slide2, text: "Memory And Data Systems" },
  { image: slide3, text: "Manifolds of scale" },
  { image: slide4, text: "Data Access Patterns" },
  { image: slide1, text: "Abstraction And Architecture" },
  { image: slide2, text: "Memory And Data Systems" },
  { image: slide3, text: "Manifolds of scale" },
  { image: slide4, text: "Data Access Patterns" },
];
---

<div class="concept-slider-wrap">
  <div class="swiper conceptSwiper">
    <div class="swiper-wrapper">
      {
        slides.map((slide) => (
          <div class="swiper-slide">
            <div class="slide-card">
              <Picture
                src={slide.image}
                formats={["avif", "webp"]}
                alt={slide.text}
              />
              <p>{slide.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
  <button class="slider-nav-btn slider-btn-prev" aria-label="Previous slide"
  ></button>
  <button class="slider-nav-btn slider-btn-next" aria-label="Next slide"
  ></button>
</div>

<script>
  import 'swiper/css';
  import 'swiper/css/navigation';

  const wrap = document.querySelector(".concept-slider-wrap");

  async function initConceptSlider() {
    const [{ default: Swiper }, { Navigation, Autoplay }] = await Promise.all([
      import("swiper"),
      import("swiper/modules"),
    ]);

    new Swiper(".conceptSwiper", {
      modules: [Navigation, Autoplay],
      slidesPerView: 4,
      loop: true,
      navigation: {
        nextEl: ".slider-btn-next",
        prevEl: ".slider-btn-prev",
      },
      autoplay: {
        delay: 3000,
        disableOnInteraction: true,
      },
      breakpoints: {
        320: { slidesPerView: 2 },
        991: { slidesPerView: 3 },
        1199: { slidesPerView: 4 },
      },
    });
  }
  if (wrap) {
    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            initConceptSlider();
          }
        },
        { rootMargin: "300px" },
      );
      observer.observe(wrap);
    } else {
      initConceptSlider();
    }
  }
</script>

<style>
  .conceptSwiper {
    overflow: hidden;
    user-select: none;
  }

  .conceptSwiper .swiper-wrapper {
    transition-timing-function: ease-out;
    will-change: transform;
  }

  .conceptSwiper .swiper-slide {
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .concept-slider-wrap {
    position: relative;
    padding: 30px 0 0;
  }

  .concept-slider-wrap .conceptSwiper {
    width: 100%;
    padding-right: 2px !important;
  }

  .concept-slider-wrap .swiper-slide {
    height: auto;
  }

  .concept-slider-wrap .swiper-slide + .swiper-slide .slide-card {
    border-right: none;
  }

  .concept-slider-wrap .slide-card {
    text-align: center;
    padding: 10px 45px 40px;
    border: 1px solid var(--color-white-10);
    height: 100%;
  }

  .concept-slider-wrap .slide-card img {
    filter: drop-shadow(83px 119px 87px var(--color-shadow-05))
      drop-shadow(37px 53px 65px var(--color-shadow-09))
      drop-shadow(9px 13px 36px var(--color-shadow-10))
      drop-shadow(147px 212px 103px var(--color-shadow-01));
  }

  .concept-slider-wrap .slide-card p {
    margin-top: 10px;
    color: var(--color-text);
    font-family: var(--font-secondary);
    font-size: 35px;
    font-weight: 700;
    line-height: 39px;
    text-transform: uppercase;
  }

  .concept-slider-wrap .slider-nav-btn {
    width: 55px;
    height: 55px;
    background-color: transparent;
    border: 2px solid var(--color-white-100);
    border-radius: 50%;
    cursor: pointer;
    position: absolute;
    top: 50%;
    left: -80px;
    transform: translateY(-50%);
    z-index: 1;
  }

  .concept-slider-wrap .slider-nav-btn::after {
    position: absolute;
    content: "";
    width: 0;
    height: 0;
    border-top: 10px solid transparent;
    border-bottom: 10px solid transparent;
    border-right: 20px solid white;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .concept-slider-wrap .slider-nav-btn.slider-btn-next {
    left: unset;
    right: -80px;
  }

  .concept-slider-wrap .slider-btn-next::after {
    border-top: 10px solid transparent;
    border-bottom: 10px solid transparent;
    border-left: 20px solid white;
    border-right: none;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 1900px) {
    .concept-slider-wrap .slider-nav-btn {
      left: -25px;
    }
    .concept-slider-wrap .slider-nav-btn.slider-btn-next {
      right: -25px;
    }
  }
  @media (max-width: 1399px) {
    .concept-slider-wrap .slide-card {
      padding: 10px 25px 40px;
    }
    .concept-slider-wrap .slide-card p {
      font-size: 30px;
    }
  }

  @media (max-width: 767px) {
    .concept-slider-wrap {
      padding: 20px 0 60px;
    }
    .concept-slider-wrap .slider-nav-btn {
      width: 40px;
      height: 40px;
      top: unset;
      transform: translateX(-50%);
      bottom: 0;
      left: 50% !important;
      margin-left: -25px;
    }
    .concept-slider-wrap .slider-nav-btn.slider-btn-next {
      margin-left: 25px;
    }
    .concept-slider-wrap .slider-nav-btn::after {
      border-width: 6px 12px 6px 0;
    }
    .concept-slider-wrap .slider-btn-next::after {
      border-width: 6px 0 6px 12px;
    }
    .concept-slider-wrap .slide-card {
      padding: 10px 20px 20px;
    }
    .concept-slider-wrap .slide-card p {
      font-size: 16px;
      line-height: 1.4;
    }
    .concept-slider-wrap .slide-card img {
      max-height: 320px;
      width: 100%;
      object-fit: contain;
    }
  }
</style>
