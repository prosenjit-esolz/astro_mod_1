---
import { Picture } from 'astro:assets';
import SectionTitle from '../global/SectionTitle.astro';
import NewsletterForm from '../ui/NewsletterForm.astro';
import formLogo from '../../assets/images/frmlogo.png';
import formCover from '../../assets/images/form_cvr_crtn.png';
---

<section class="contact-section">
  <div class="container">
    <div class="contact-form-wrap">
      <div class="form-logo-wrap">
        <Picture  src={formLogo} alt="Code Monster logo"  formats={['avif', 'webp']} />
      </div>
      <SectionTitle
        heading="Newsletter Signup"
        body="Praesent auctor interdum accumsan. Nunc porttitor malesuada purus non mattis. Morbi dapibus, eros pretium condimentum mattis." />
        <NewsletterForm />
    </div>
    <div class="form-cartoon">
        <Picture src={formCover} alt="form-cartoon" formats={['avif', 'webp']} aria-hidden="true" widths={[480, 800, 1200, 1547]} sizes="(max-width: 767px) 480px, (max-width: 1900px) 800px, 1547px" />
    </div>
  </div>
</section>



<style>


  /* ── Section ────────────────────────────────────────────── */
  .contact-section {
    padding: 100px 0 20px;
    background: linear-gradient(0deg, var(--color-crimson-0) 55%, var(--color-crimson-40) 85%);
    overflow: hidden;
  }

  /* ── Form card ──────────────────────────────────────────── */
  .contact-form-wrap {
    max-width: 1115px;
    margin-inline: auto;
    padding: 0 120px 100px;
    border-radius: 30px;
    backdrop-filter: blur(24px);
    background: linear-gradient(
      180deg,
      rgba(198, 62, 255, 0.2) 0%,
      var(--color-form-overlay) 100%
    );
  }

  /* ── Logo ───────────────────────────────────────────────── */
  .form-logo-wrap {
    text-align: center;
  }

  .form-logo-wrap img {
    margin-top: -95px;
  }
  /* ── Cartoon ────────────────────────────────────────────── */
  .form-cartoon {
    text-align: center;
    margin-top: -270px;
    position: relative;
    pointer-events: none;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 1900px) {
    .form-cartoon{
      margin-inline: -80px;
    }
  }
  @media (max-width: 991px)  {
      .contact-form-wrap {
        padding: 0 20px 100px;
    }
    .form-cartoon{
      margin-top: -200px;
    }

  }
  @media (max-width: 767px)  {
    .form-logo-wrap img {
        margin-top: -42px;
        width: 120px;
    }
    .contact-section{
      padding: 60px 0 20px;
    }
    .form-cartoon{
        margin-top: -150px;
        margin-inline: -40px;
    }
  }
</style>