---
interface Props {
  variant?: 'primary' | 'secondary';
  href?: string;
  text: string;
  [key: string]: unknown;
}

const { scrollTo, variant = 'primary', href, text, ...rest } = Astro.props;

const variantClass = variant === 'secondary' ? 'btn-secondary' : 'btn-primary';
---

{
  href ? (
    <a href={href} class={`btn ${variantClass}`} {...rest}>
      <span>{text}</span>
    </a>
  ) : (
    <button class={`btn ${variantClass}`} {...rest} onclick={scrollTo? `document.getElementById('${scrollTo}')?.scrollIntoView({ behavior: 'smooth' })` : undefined}>
      <span>{text}</span>
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    height: 55px;
    padding: 0 33px;
    justify-content: center;
    font-size: 20px;
    font-weight: 500;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
    border-radius: 8px;
  }

  /* ── Primary ─────────────────────────────────────────────── */
  .btn-primary {
    box-shadow: inset 0px -5px 3px 0px var(--color-gold-shadow);
    background: var(--gradient-gold);
    color: var(--color-bg-dark);
  }

  .btn-primary::before {
    position: absolute;
    content: '';
    width: calc(100% - 4px);
    height: calc(100% - 4px);
    top: 2px;
    left: 2px;
    background-color: var(--color-bg-dark);
    border-radius: 8px;
    z-index: -1;
    transform: scale(0);
    transition: 400ms all ease-in-out;
  }

  .btn-primary:hover {
    color: var(--color-text);
  }

  .btn-primary:hover::before {
    transform: scale(1);
  }

  /* ── Secondary ───────────────────────────────────────────── */
  .btn-secondary {
  position: relative;
  isolation: isolate;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 1;
  box-shadow:  0 7px  25px 0 rgba(255, 255, 255, 0.22);
}

.btn-secondary span {
  color: transparent;
  background: var(--gradient-gold);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  transition: 400ms all ease-in-out;
}

.btn-secondary::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: var(--gradient-gold);
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  z-index: -1;
}

.btn-secondary::before {
  position: absolute;
  content: "";
  inset: 0;
  border-radius: 8px;
  background: var(--gradient-gold);
  z-index: -1;
  transition: 400ms all ease-in-out;
  transform: scale(0);
}

.btn-secondary:hover span {
  background: none;
  color: var(--color-bg-dark);
  -webkit-text-fill-color: var(--color-bg-dark);
}

.btn-secondary:hover::before {
  transform: scale(1);
}

  @media(max-width: 767px){
    .btn {
        height: 45px;
        padding: 0 16px;
        font-size: 15px;
        letter-spacing: -0.02em;
    }
  }
</style>
